# ── LLM Provider ──────────────────────────────────────────────────
# Options: groq | openai
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here     # only needed if LLM_PROVIDER=openai
LLM_MODEL=llama-3.3-70b-versatile           # override default model if needed

# ── Database ───────────────────────────────────────────────────────
# Options: mongo | postgres
DB_TOOL_MODE=mongo
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/
DB_NAME=leafy_store

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=leafy_popup_store
POSTGRES_USER=leafy
POSTGRES_PASSWORD=changeme
POSTGRES_MAX_CONNECTIONS=10


# ── Vision (screenshot parsing) ────────────────────────────────────
# Options: groq | mock
VISION_MODE=groq
VISION_MODEL=llama-4-scout-17b-16e-instruct  # Groq multimodal model

# ── Policy / Knowledge Store ───────────────────────────────────────
# Options: file | rag
POLICY_STORE=file
KNOWLEDGE_DIR=./knowledge                    # swap to ./clients/brandA for multi-tenant
# RAG-only (ignored when POLICY_STORE=file)
VECTOR_DB_URL=your_vector_db_url_here
VECTOR_DB_API_KEY=your_vector_db_key_here

# ── Session Store ──────────────────────────────────────────────────
# Options: memory | redis
SESSION_STORE=memory
REDIS_URL=redis://localhost:6379             # only needed if SESSION_STORE=redis

# ── App Settings ───────────────────────────────────────────────────
APP_ENV=development                          # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173           # frontend dev server

# ── Auth (mock in dev) ─────────────────────────────────────────────
AUTH_MODE=mock                               # mock | jwt
JWT_SECRET=your_jwt_secret_here             # only needed if AUTH_MODE=jwt
